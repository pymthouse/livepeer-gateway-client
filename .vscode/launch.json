{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "write_frames (raw API key — webhook-validated signer)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "program": "${workspaceFolder}/examples/write_frames.py",
            "args": [
                "--signer",
                "http://localhost:8081",
                "--api-key",
                "sk_demo_local_key",
                "--discovery",
                "https://discovery-service-production-8955.up.railway.app/v1/discovery/raw?serviceType=legacy",
                "--model",
                "streamdiffusion-sdxl",
                "--count",
                "90000"
            ],
            "env": {
                "LOG_LEVEL": "INFO"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "write_frames (API key exchange — dashboard BFF)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "program": "${workspaceFolder}/examples/write_frames.py",
            "args": [
                "--discovery",
                "https://discovery-service-production-8955.up.railway.app/v1/discovery/raw?serviceType=legacy",
                "--billing-url",
                "http://localhost:3000",
                "--client-id",
                "app_bf4a4dd275594713afe37052",
                "--api-key",
                "pmth_BEARER_KEY_HERE",
                "--model",
                "streamdiffusion-sdxl",
                "--count",
                "900000"
            ],
            "env": {
                "LOG_LEVEL": "INFO"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
